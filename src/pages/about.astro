import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Eliot Attridge">
  <article class="note-article">
    <header class="note-header">
      <div class="crumbs"><a href="/">Notes</a></div>
      <h1>About</h1>
    </header>
    <div class="prose">
      <p>
        I'm Eliot Attridge. I teach senior science at Marlborough Boys' College in Aotearoa New Zealand,
        lead AI and digital learning across two schools, and spend a lot of time tinkering at the seam
        between learning science, technology, and the natural world.
      </p>
      <p>
        I have a PhD in microbiology, twenty-something years in classrooms across the UK and NZ, and
        an ADHD brain that does its best work in the small hours. I co-author school biology textbooks,
        examine internationally for OCR, and run a small edtech company called Pursue Learning.
      </p>
      <p>
        This site is none of those things. It's a thinking space for half-formed ideas, reading notes,
        field observations, and arguments I'm still working out. Notes are allowed to be unfinished,
        contradict each other, and quietly evolve over years. If you want my finished writing for
        teachers, that's at <a href="https://www.pursuelearning.net">pursuelearning.net</a>.
      </p>
      <p>
        Find me at <a href="mailto:drema@eliotattridge.com">drema@eliotattridge.com</a>.
      </p>
    </div>
  </article>
</BaseLayout>
