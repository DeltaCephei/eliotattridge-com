---
import { getCollection, render } from 'astro:content';
import NoteLayout from '../layouts/NoteLayout.astro';
import Aside from '../components/Aside.astro';
import Figure from '../components/Figure.astro';
import IntroParagraph from '../components/IntroParagraph.astro';
import Footnote from '../components/Footnote.astro';
import Ref from '../components/Ref.astro';
import References from '../components/References.astro';
import Reference from '../components/Reference.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// MDX components available in every note without import.
const components = { Aside, Figure, IntroParagraph, Footnote, Ref, References, Reference };

// All five kinds currently render through NoteLayout — it has conditional
// kind-specific blocks (link source card, reading book card) so a single
// layout serves them all in v1. Splitting into per-kind layouts is one
// new file each, when a real piece of content demands it.
//
// The `layout` frontmatter field is the escape hatch for one-off bespoke
// treatments — not used yet, but the switch is here for when it is.
const data = entry.data as any;
---
<NoteLayout
  slug={entry.id}
  kind={data.kind}
  title={data.title}
  startDate={data.startDate}
  updated={data.updated}
  topics={data.topics}
  summary={data.summary}
  source={data.source}
  book={data.book}
  quote={data.quote}
>
  <Content components={components} />
</NoteLayout>
