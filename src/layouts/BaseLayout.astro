---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  pathname?: string;
}

const { title, description = "Eliot Attridge — half-formed notes from the seam of science, learning, and technology.", pathname = Astro.url.pathname } = Astro.props;

const navItems = [
  { href: '/', label: 'Latest' },
  { href: '/streams/', label: 'Streams' },
  { href: '/topics/', label: 'Topics' },
  { href: '/about/', label: 'About' },
  { href: '/now/', label: 'Now' },
  { href: '/colophon/', label: 'Colophon' },
];

const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};
---
<!doctype html>
<html lang="en-NZ">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" type="application/rss+xml" title="Eliot Attridge — notes" href="/rss.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
</head>
<body>
  <main class="page">
    <slot name="masthead">
      <header class="masthead masthead--inner">
        <h1><a href="/">Eliot Attridge</a></h1>
        <p class="tagline">Half-formed notes from the seam of science, learning, and technology</p>
      </header>
    </slot>

    <nav class="nav" aria-label="Primary">
      {navItems.map(item => (
        <a href={item.href} class={isActive(item.href) ? 'is-active' : ''}>{item.label}</a>
      ))}
    </nav>

    <div id="search"></div>

    <slot />

    <footer class="colophon">
      Started 2026 &nbsp;·&nbsp; Marlborough, Aotearoa New Zealand &nbsp;·&nbsp; CC BY-NC 4.0 &nbsp;·&nbsp; <a href="/rss.xml">RSS</a>
    </footer>
  </main>
  <script is:inline>
    // Load Pagefind UI dynamically (is:inline + src= is broken in Astro)
    var s = document.createElement('script');
    s.src = '/pagefind/pagefind-ui.js';
    s.onload = function() {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      });
    };
    document.head.appendChild(s);
  </script>
</body>
</html>
